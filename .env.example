# Groq LLM (create key at https://console.groq.com/keys)
GROQ_API_KEY=replace-me-with-real-key
GROQ_MODEL=llama3-8b-8192

# Paths
# - On the host (running `uv run uvicorn ...` from backend/), the defaults below resolve
#   relative to backend/app/core/config.py -> ROOT_DIR (= backend/).
# - Inside Docker (docker-compose.yml sets WORKDIR /app), bind mounts place chroma_store
#   and logs at /app/data/chroma_store and /app/logs respectively.
# - To run the Docker stack, override these to container-absolute paths:
#       CHROMA_PATH=/app/data/chroma_store
#       LOG_PATH=/app/logs/queries.jsonl
#   MODEL_PATH stays as-is because the .pkl is baked into the image.
CHROMA_PATH=./data/chroma_store
MODEL_PATH=./app/models/priority_model.pkl
LOG_PATH=./logs/queries.jsonl

# Embeddings + retrieval
EMBEDDING_MODEL=all-MiniLM-L6-v2
TOP_K_RESULTS=3
